# Neon pooled connection string. Use the URL whose hostname contains "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@HOST-POOLER/DATABASE?sslmode=require"

# Neon direct connection string for Prisma migrations. Its hostname does not contain "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Generate a unique value with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-a-long-random-secret"

# Generate a second, different value with the same command.
CRON_SECRET="replace-with-another-long-random-secret"
