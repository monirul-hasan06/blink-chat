# Neon pooled connection. The hostname normally contains "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@HOST-POOLER/DATABASE?sslmode=require"

# Neon direct connection for Prisma migrations. The hostname does not contain "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Generate two different secrets with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-a-long-random-secret"
CRON_SECRET="replace-with-another-long-random-secret"

# Generate once with: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY="replace-with-vapid-public-key"
VAPID_PRIVATE_KEY="replace-with-vapid-private-key"

# Use an email address you control.
VAPID_SUBJECT="mailto:you@example.com"
